# JWT signing secret — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_a_long_random_secret

# JWT token lifetime (ms units or zeit/ms strings: 15m, 1h, 7d)
JWT_EXPIRES_IN=15m

# Server port
PORT=3000

# Path to the SQLite database file (relative to project root)
DB_PATH=./data/customers.db
